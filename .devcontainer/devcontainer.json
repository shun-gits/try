{
    "name": "stock-data-factory Dev Environment",
    "build": {
        "dockerfile": "./dockerfiles/dev.Dockerfile",
        "context": ".."
    },
    //"workspaceMount": "source=${localWorkspaceFolder},target=/workspace/app,type=bind",
    //"workspaceFolder": "/workspace/app",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": true,
            "upgradePackages": true,
            "username": "vscode",
            "userUid": "1000",
            "userGid": "1000"
        }
    },
    "mounts": [
        "source=market-advisor-codex,target=/home/vscode/.codex,type=volume",
        "source=${localWorkspaceFolder}/../stock-data-factory-raw-data,target=/workspaces/data,type=bind"
    ],
    "forwardPorts": [
        3000
    ],
    "containerEnv": {
        "DATA_DIR": "/workspaces/data",
        "DAGSTER_HOME": "${containerWorkspaceFolder}/local_dagster_state_metadata",
        "PYTHONPATH": "${containerEnv:PYTHONPATH}:${containerWorkspaceFolder}"
    },
    "postCreateCommand": "mkdir -p $DAGSTER_HOME /home/vscode/.codex && sudo chown -R vscode:vscode /home/vscode/.codex && git config --global user.name \"shun-gits\" && git config --global user.email \"shun.apps@gmail.com\"",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "charliermarsh.ruff",
                "ms-python.debugpy",
                "tamasfe.even-better-toml",
                "openai.chatgpt",
                "corschenzi.mermaid-graphical-editor",
                "github.vscode-pull-request-github",
                "anthropic.claude-code"

            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.analysis.extraPaths": [
                    "${containerWorkspaceFolder}"
                ]
            }
        }
    },
    "remoteUser": "vscode",
    "runArgs": [
  "--security-opt",
  "seccomp=unconfined"
]
}
